# 第一阶段：编译 Go 程序
FROM golang:1.21-alpine AS builder
WORKDIR /build
COPY go.mod ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -o /build/minidocker .

# 第二阶段：仅作为 Alpine 文件系统源
FROM alpine:3.21 AS rootfs

# 第三阶段：最终镜像
FROM scratch
COPY --from=builder /build/minidocker /usr/bin/minidocker
COPY --from=rootfs / /var/lib/minidocker/images/alpine/rootfs
ENTRYPOINT ["/usr/bin/minidocker"]